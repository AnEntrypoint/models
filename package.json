{
  "name": "models",
  "version": "1.0.0",
  "description": "Private credentials and state for hydl — Hunyuan 3D asset downloads",
  "private": true,
  "scripts": {
    "download": "SKIP_CONVERT=1 node node_modules/hydl/downloader.js",
    "convert": "node convert.js",
    "sync": "bun run download && bun run convert",
    "prompt": "bun x --package hydl hydl-prompt",
    "list": "node -e \"fetch('https://raw.githubusercontent.com/AnEntrypoint/assets/master/docs/manifest.json').then(r=>r.json()).then(d=>Object.values(d).flat().forEach(m=>console.log(m.name)))\"",
    "auth": "bun x --package hydl hydl",
    "batch": "node batch-prompt.js",
    "ui": "node serve.js"
  },
  "dependencies": {
    "anentrypoint-design": "^0.0.29",
    "hydl": "^1.0.3"
  },
  "devDependencies": {
    "@gltf-transform/cli": "^4.3.0"
  }
}
